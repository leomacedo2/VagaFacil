# Copie este arquivo para ".env" na raiz do projeto e preencha com suas
# próprias credenciais. Nenhum destes valores é secreto o suficiente para
# ficar oculto do bundle final (são chaves de front-end), mas mesmo assim
# não devem ser commitados — o .env já está no .gitignore padrão do Vite.

# --- Firebase (Authentication + Firestore) ---
# Console: https://console.firebase.google.com -> Configurações do projeto
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- EmailJS (envio do e-mail de confirmação de reserva) ---
# Painel: https://dashboard.emailjs.com
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
